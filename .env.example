# Supabase (supports Vercel/Supabase integration names)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional explicit Next.js client names
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Postgres (used by scripts/apply-migrations.mjs)
POSTGRES_HOST=db.your-project.supabase.co
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_DATABASE=postgres
POSTGRES_URL_NON_POOLING=postgres://postgres.your-project:your-db-password@db.your-project.supabase.co:5432/postgres

# Email (Resend)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL="Dave Survey <reports@yourdomain.com>"
